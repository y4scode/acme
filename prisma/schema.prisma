generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String

  @@map("users")
}

model Customer {
  id String @id @default(uuid())
  name String
  email String @unique
  imageUrl String @map("image_url")

  invoices Invoice[]

  @@map("customers")
}

enum InvoiceStatus {
  PENDENTE
  PAGO
}

model Invoice {
  id String @id @default(uuid())
  amount Int
  status InvoiceStatus
  date DateTime

  customerId String @map("customer_id")
  customer Customer @relation(fields: [customerId], references: [id])

  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  @@index([customerId])

  @@map("invoices")
}

model Revenue {
  id String @id @default(uuid())
  month String @unique
  revenue Int

  @@map("revenues")
}